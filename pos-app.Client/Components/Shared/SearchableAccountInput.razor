@using Microsoft.AspNetCore.Components
@using pos_app.Client.Services
@using pos_app.Client.Models
@inject DataService DataService
@implements IDisposable

<div class="@ColumnClass">
    <label for="@Id" class="form-label">@Label</label>
    <div class="position-relative account-search-container">
        <div class="input-group">
            <input type="text" 
                   id="@Id"
                   class="form-control @(AdditionalClass ?? "")" 
                   placeholder="@Placeholder" 
                   value="@accountSearchTerm"
                   disabled="@IsDisabled"
                   readonly="@(!HideBrowseButton)"
                   @oninput="OnAccountSearchChanged"
                   @onfocus="@(() => { if (HideBrowseButton) ShowAccountDropdown = true; })"
                   @onblur="HideAccountDropdown"
                   style="--search-input-padding: @(HideBrowseButton ? "35px" : "75px"); cursor: @(HideBrowseButton ? "text" : "pointer"); background-color: @(HideBrowseButton ? "#fff" : "#f8f9fa");"
                   @onclick="@(() => { if (!HideBrowseButton) OpenChartModal(); })" />
            
            @if (!string.IsNullOrEmpty(accountSearchTerm))
            {
                <button type="button" 
                        class="btn btn-sm position-absolute top-50 translate-middle-y p-0 clear-search-btn" 
                        style="background: none; border: none; color: #6c757d; z-index: 10; right: @(HideBrowseButton ? "12px" : "54px");"
                        @onclick="ClearSearch"
                        title="Clear search">
                    <i class="fas fa-times"></i>
                </button>
            }
            
            @if (!HideBrowseButton)
            {
                <button type="button" 
                        class="btn btn-outline-secondary browse-chart-btn"
                        disabled="@IsDisabled"
                        @onclick="OpenChartModal"
                        title="Browse Account Chart">
                    <i class="fas fa-sitemap"></i>
                </button>
            }
        </div>
        
        @if (ShowAccountDropdown && filteredAccounts.Any())
        {
            <div class="position-absolute w-100 account-dropdown" 
                 style="top: 100%; z-index: 99999; background: white; border: 1px solid #dee2e6; border-top: none; left: 0; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
                @foreach (var account in filteredAccounts.Take(10))
                {
                    <div class="account-item" 
                         @onclick="() => SelectAccount(account)"
                         @onmouseover="@(() => hoveredAccount = account.AccCode)"
                         @onmouseout="@(() => hoveredAccount = null)">
                        <strong>@account.AccCode.Trim()</strong> - @account.AccName.Trim()
                    </div>
                }
            </div>
        }
    </div>
</div>

<AccountChartModal @bind-IsVisible="isChartModalVisible" 
                   Title="@GetModalTitle()"
                   OnAccountSelected="OnAccountFromModalSelected"
                   IsRangeMode="@IsRangeInput" />

<style>
    .account-dropdown {
        max-height: 200px;
        overflow-y: auto;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        border-radius: 0 0 0.375rem 0.375rem;
    }
    
    .account-item {
        padding: 8px 12px;
        cursor: pointer;
        border-bottom: 1px solid #eee;
    }
    
    .account-item:hover {
        background-color: #f8f9fa;
    }
    
    .account-item.selected {
        background-color: #007bff;
        color: white;
    }
    
    .clear-search-btn:hover {
        color: #dc3545 !important;
        background-color: rgba(220, 53, 69, 0.1) !important;
    }

    /* Ensure dropdown is not clipped by parent containers */
    .account-search-container {
        overflow: visible !important;
    }
    
    /* Additional dropdown styling for better visibility */
    .account-dropdown {
        z-index: 99999 !important;
        position: absolute !important;
        max-height: 300px !important;
        overflow-y: auto !important;
    }

    .account-search-container .form-control {
        padding-right: var(--search-input-padding, 75px) !important;
    }
</style>

@code {
    // Parameter to conditionally hide the chart sitemap browse button
    [Parameter] public bool HideBrowseButton { get; set; } = false;

    // Label text for the field
    [Parameter] public string Label { get; set; } = string.Empty;

    // Currently selected account code
    [Parameter] public string Value { get; set; } = string.Empty;

    // Event callback when account changes
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    // Placeholder text
    [Parameter] public string? Placeholder { get; set; }

    // HTML id attribute
    [Parameter] public string? Id { get; set; }

    // Additional CSS classes
    [Parameter] public string? AdditionalClass { get; set; }

    // Bootstrap column class (e.g., "col-12 col-md-3", "col-12 col-sm-6 col-md-4")
    [Parameter] public string ColumnClass { get; set; } = "col-12 col-md-3";

    // Whether the input is disabled
    [Parameter] public bool IsDisabled { get; set; } = false;

    // Optional account type to filter by (e.g., "D" for Detail accounts)
    [Parameter] public string? AccountTypeFilter { get; set; }

    private List<ClientCustomer> allAccounts = new();
    private List<ClientCustomer> filteredAccounts = new();
    private string accountSearchTerm = "";
    private string selectedAccountCode = "";
    private string selectedAccountDisplay = "";
    private string? hoveredAccount = null;
    private bool ShowAccountDropdown = false;
    private bool isChartModalVisible = false;

    // Detect if this is a "From" or "Upto" field for range selection
    private bool IsRangeInput => IsFromInput || IsUptoInput;
    private bool IsFromInput => !string.IsNullOrEmpty(Label) && 
        (Label.Contains("From", StringComparison.OrdinalIgnoreCase));
    private bool IsUptoInput => !string.IsNullOrEmpty(Label) && 
        (Label.Contains("Upto", StringComparison.OrdinalIgnoreCase) || 
         Label.Contains("Up to", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
        
        // If Value is already set, find and display the account
        if (!string.IsNullOrWhiteSpace(Value))
        {
            var account = allAccounts.FirstOrDefault(a => a.AccCode.Trim() == Value.Trim());
            if (account != null)
            {
                selectedAccountCode = account.AccCode;
                selectedAccountDisplay = $"{account.AccCode.Trim()} - {account.AccName.Trim()}";
                accountSearchTerm = selectedAccountDisplay;
            }
            else
            {
                accountSearchTerm = Value;
            }
        }

        // Subscribe to range selection events
        if (IsFromInput)
        {
            AccountSelectionState.OnFromAccountSelected += HandleRangeFromSelected;
        }
        else if (IsUptoInput)
        {
            AccountSelectionState.OnUptoAccountSelected += HandleRangeUptoSelected;
        }
    }

    protected override void OnParametersSet()
    {
        // Update display when Value changes from outside
        if (!string.IsNullOrWhiteSpace(Value) && Value != selectedAccountCode)
        {
            var account = allAccounts.FirstOrDefault(a => a.AccCode.Trim() == Value.Trim());
            if (account != null)
            {
                selectedAccountCode = account.AccCode;
                selectedAccountDisplay = $"{account.AccCode.Trim()} - {account.AccName.Trim()}";
                accountSearchTerm = selectedAccountDisplay;
            }
            else
            {
                accountSearchTerm = Value;
                selectedAccountCode = Value;
            }
        }
        else if (string.IsNullOrWhiteSpace(Value) && !string.IsNullOrWhiteSpace(selectedAccountCode))
        {
            // Value was cleared
            accountSearchTerm = "";
            selectedAccountCode = "";
            selectedAccountDisplay = "";
        }
    }

    private async Task LoadAccounts()
    {
        try
        {
            var accounts = await DataService.GetCustomersAsync();
            if (!string.IsNullOrEmpty(AccountTypeFilter))
            {
                allAccounts = accounts.Where(a => a.AccType.Trim().ToUpper() == AccountTypeFilter.Trim().ToUpper()).ToList();
            }
            else
            {
                allAccounts = accounts.ToList();
            }
            filteredAccounts = allAccounts.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading accounts: {ex.Message}");
        }
    }

    private void OnAccountSearchChanged(ChangeEventArgs e)
    {
        accountSearchTerm = e.Value?.ToString() ?? "";
        
        // Don't filter if we have a selected account and the search term matches it
        if (!string.IsNullOrEmpty(selectedAccountCode) && accountSearchTerm == selectedAccountDisplay)
        {
            filteredAccounts = allAccounts.ToList();
            ShowAccountDropdown = false;
        }
        else
        {
            if (string.IsNullOrEmpty(accountSearchTerm))
            {
                filteredAccounts = allAccounts.ToList();
            }
            else
            {
                var searchLower = accountSearchTerm.Trim().ToLower();
                filteredAccounts = allAccounts.Where(a => 
                    a.AccCode.Trim().ToLower().Contains(searchLower) ||
                    a.AccName.Trim().ToLower().Contains(searchLower)
                ).ToList();
            }
            
            ShowAccountDropdown = true;
        }
        
        StateHasChanged();
    }

    private void SelectAccount(ClientCustomer account)
    {
        selectedAccountCode = account.AccCode;
        selectedAccountDisplay = $"{account.AccCode.Trim()} - {account.AccName.Trim()}";
        accountSearchTerm = selectedAccountDisplay;
        ShowAccountDropdown = false;
        
        // Update the Value and notify parent
        Value = selectedAccountCode;
        ValueChanged.InvokeAsync(selectedAccountCode);
        
        StateHasChanged();
    }

    private async Task HideAccountDropdown()
    {
        await Task.Delay(200); // Small delay to allow click events
        ShowAccountDropdown = false;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        accountSearchTerm = "";
        selectedAccountCode = "";
        selectedAccountDisplay = "";
        filteredAccounts = allAccounts.ToList();
        ShowAccountDropdown = false;
        
        // Clear the Value and notify parent
        Value = "";
        ValueChanged.InvokeAsync("");
        
        StateHasChanged();
    }

    private void OpenChartModal()
    {
        isChartModalVisible = true;
    }

    private void OnAccountFromModalSelected(ClientCustomer account)
    {
        // Single selection mode callback — used when NOT in range mode
        SelectAccount(account);
    }

    private void HandleRangeFromSelected(string code, int level)
    {
        // Only "From" inputs listen to this event
        selectedAccountCode = code;
        selectedAccountDisplay = code;
        accountSearchTerm = code;
        Value = code;
        ValueChanged.InvokeAsync(code);
        InvokeAsync(StateHasChanged);
    }

    private void HandleRangeUptoSelected(string code, int level)
    {
        // Only "Upto" inputs listen to this event
        selectedAccountCode = code;
        selectedAccountDisplay = code;
        accountSearchTerm = code;
        Value = code;
        ValueChanged.InvokeAsync(code);
        InvokeAsync(StateHasChanged);
    }

    private string GetModalTitle()
    {
        var cleanLabel = Label?.Replace(":", "").Trim() ?? "Account";
        if (IsRangeInput)
        {
            return "Browse Account Range";
        }
        return $"Browse {cleanLabel}";
    }

    public void Dispose()
    {
        if (IsFromInput)
        {
            AccountSelectionState.OnFromAccountSelected -= HandleRangeFromSelected;
        }
        else if (IsUptoInput)
        {
            AccountSelectionState.OnUptoAccountSelected -= HandleRangeUptoSelected;
        }
    }
}
