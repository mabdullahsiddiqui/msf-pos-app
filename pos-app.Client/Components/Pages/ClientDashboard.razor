@page "/dashboard"
@using pos_app.Client.Services
@using pos_app.Client.Models
@inject DataService DataService
@inject IJSRuntime JSRuntime

<PageTitle>Client Dashboard</PageTitle>

<div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h2 class="mb-4">
                    <i class="fas fa-chart-line me-2"></i>
                    Client Dashboard
                    @if (!string.IsNullOrEmpty(dashboardData.MonthName))
                    {
                        <small class="text-muted ms-2">- @dashboardData.MonthName</small>
                    }
                </h2>
            </div>
        </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading dashboard data...</p>
        </div>
    }
    else if (connectionError)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Connection Error:</strong> Unable to connect to your database. Please check your database connection settings.
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="TestConnection">
                <i class="fas fa-sync-alt me-1"></i>
                Test Connection
            </button>
        </div>
    }
    else
    {
        <!-- Statistics Cards -->
        <div class="row mb-4 g-3">
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="card-title">Total Sales</h4>
                                <h2>@CurrencyHelper.FormatNumber(dashboardData.TotalSales)</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-dollar-sign fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="card-title">Total Purchases</h4>
                                <h2>@CurrencyHelper.FormatNumber(dashboardData.TotalPurchases)</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-shopping-cart fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="card-title">Net Profit</h4>
                                <h2>@CurrencyHelper.FormatNumber(dashboardData.NetProfit)</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-chart-line fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="card-title">Total Customers</h4>
                                <h2>@dashboardData.TotalCustomers</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-users fa-2x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Trend Chart Row -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-chart-line text-primary me-2"></i>
                            Sales, Recovery & Expenses Trend
                        </h5>
                    </div>
                    <div class="card-body">
                        <div style="height: 350px;" class="position-relative">
                            @if (comparisonData == null || !comparisonData.Any())
                            {
                                <div class="position-absolute top-50 start-50 translate-middle text-center text-muted">
                                    <i class="fas fa-chart-area fa-3x mb-3 opacity-25"></i>
                                    <p class="mb-0">No trend data available.</p>
                                </div>
                            }
                            <canvas id="comparisonChart" style='display: @(comparisonData?.Any() == true ? "block" : "none")'></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Distribution Charts Row -->
        <div class="row mb-4 g-4">
            <!-- Production Distribution Chart -->
            <div class="col-12 col-xl-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-industry text-success me-2"></i>
                            Production Analysis
                        </h5>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn @(productionPeriod == "all" ? "btn-success" : "btn-outline-success")" @onclick='() => ChangeProductionPeriod("all")'>All</button>
                            <button type="button" class="btn @(productionPeriod == "today" ? "btn-success" : "btn-outline-success")" @onclick='() => ChangeProductionPeriod("today")'>Today</button>
                            <button type="button" class="btn @(productionPeriod == "week" ? "btn-success" : "btn-outline-success")" @onclick='() => ChangeProductionPeriod("week")'>Week</button>
                            <button type="button" class="btn @(productionPeriod == "month" ? "btn-success" : "btn-outline-success")" @onclick='() => ChangeProductionPeriod("month")'>Month</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div style="height: 350px;" class="position-relative">
                            @if (isProductionLoading)
                            {
                                <div class="position-absolute top-50 start-50 translate-middle">
                                    <div class="spinner-border text-success" role="status"></div>
                                </div>
                            }
                            else if (productionData == null || !productionData.Any())
                            {
                                <div class="position-absolute top-50 start-50 translate-middle text-center text-muted">
                                    <i class="fas fa-database fa-3x mb-3 opacity-25"></i>
                                    <p class="mb-0">No production data found.</p>
                                </div>
                            }
                            <canvas id="productionChart" style='display: @(productionData?.Any() == true ? "block" : "none")'></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sales Distribution Chart -->
            <div class="col-12 col-xl-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-shopping-cart text-info me-2"></i>
                            Sales Analysis
                        </h5>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn @(salesPeriod == "all" ? "btn-info text-white" : "btn-outline-info")" @onclick='() => ChangeSalesPeriod("all")'>All</button>
                            <button type="button" class="btn @(salesPeriod == "today" ? "btn-info text-white" : "btn-outline-info")" @onclick='() => ChangeSalesPeriod("today")'>Today</button>
                            <button type="button" class="btn @(salesPeriod == "week" ? "btn-info text-white" : "btn-outline-info")" @onclick='() => ChangeSalesPeriod("week")'>Week</button>
                            <button type="button" class="btn @(salesPeriod == "month" ? "btn-info text-white" : "btn-outline-info")" @onclick='() => ChangeSalesPeriod("month")'>Month</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div style="height: 350px;" class="position-relative">
                            @if (isSalesLoading)
                            {
                                <div class="position-absolute top-50 start-50 translate-middle">
                                    <div class="spinner-border text-info" role="status"></div>
                                </div>
                            }
                            else if (salesData == null || !salesData.Any())
                            {
                                <div class="position-absolute top-50 start-50 translate-middle text-center text-muted">
                                    <i class="fas fa-cash-register fa-3x mb-3 opacity-25"></i>
                                    <p class="mb-0">No sales data found.</p>
                                </div>
                            }
                            <canvas id="salesChart" style='display: @(salesData?.Any() == true ? "block" : "none")'></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CEO Summary Tables -->
        <div class="row mb-4">
            <!-- Performance Summary -->
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-file-invoice-dollar text-primary me-2"></i>
                            Executive Performance Summary
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Period</th>
                                        <th class="text-end">Sales</th>
                                        <th class="text-end">Sales Ret</th>
                                        <th class="text-end">Net Sales</th>
                                        <th class="text-end">Recovery</th>
                                        <th class="text-end pe-4">Purchase</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ceoReport.PerformanceSummary?.Any() == true)
                                    {
                                        @foreach (var row in ceoReport.PerformanceSummary)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-semibold">@row.Legend</td>
                                                <td class="text-end">@row.Sales.ToString("N0")</td>
                                                <td class="text-end text-danger">@row.SalesRet.ToString("N0")</td>
                                                <td class="text-end fw-bold text-primary">@row.NetSales.ToString("N0")</td>
                                                <td class="text-end text-success">@row.Recovery.ToString("N0")</td>
                                                <td class="text-end pe-4 text-warning">@row.Purchase.ToString("N0")</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center py-4 text-muted">No summary data available.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bank Summary -->
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-university text-info me-2"></i>
                            Bank Balance Summary
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Account</th>
                                        <th class="text-end">Prev. Balance</th>
                                        <th class="text-end">Debit (In)</th>
                                        <th class="text-end">Credit (Out)</th>
                                        <th class="text-end pe-4">Current Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ceoReport.BankSummary?.Any() == true)
                                    {
                                        @foreach (var row in ceoReport.BankSummary)
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <div class="fw-semibold">@row.AccName</div>
                                                </td>
                                                <td class="text-end">@row.PrevBalance.ToString("N0") <span class="badge @(row.PrevType == "Dr." ? "bg-success" : "bg-danger")">@row.PrevType</span></td>
                                                <td class="text-end text-success">@row.Debit.ToString("N0")</td>
                                                <td class="text-end text-danger">@row.Credit.ToString("N0")</td>
                                                <td class="text-end pe-4 fw-bold">@row.CurBal.ToString("N0") <span class="badge @(row.CurType == "Dr." ? "bg-success" : "bg-danger")">@row.CurType</span></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted">No bank data found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="fas fa-tachometer-alt me-2"></i>
                            Quick Actions - Reports
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <!-- Trial Balance -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/trial-balance" class="report-card-link">
                                    <div class="report-card bg-primary text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-file-alt fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Trial Balance</h6>
                                            <p class="report-card-description">View account balances and totals</p>
                                        </div>
                                    </div>
                                </a>
                            </div>


                            <!-- 3 Trial Balance -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/three-trial-balance" class="report-card-link">
                                    <div class="report-card bg-info text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-file-text fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">3 Trial Balance</h6>
                                            <p class="report-card-description">Three-column trial balance report</p>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Monthly Account Balance -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/monthly-account-balance" class="report-card-link">
                                    <div class="report-card bg-warning text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-calendar-alt fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Month Wise Report</h6>
                                            <p class="report-card-description">Monthly account balance summary</p>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Ledger Report -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/ledger" class="report-card-link">
                                    <div class="report-card bg-danger text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-journal-whills fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Ledger Report</h6>
                                            <p class="report-card-description">Detailed ledger transactions</p>
                                        </div>
                                    </div>
                                </a>
                            </div>


                            <!-- Cash Book -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/cash-book" class="report-card-link">
                                    <div class="report-card bg-dark text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-book-open fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Cash Book</h6>
                                            <p class="report-card-description">Track cash receipts and payments</p>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Journal Book -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/journal-book" class="report-card-link">
                                    <div class="report-card bg-secondary text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-journal-whills fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Journal Book</h6>
                                            <p class="report-card-description">View journal voucher entries</p>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Transaction Journal -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/transaction-journal" class="report-card-link">
                                    <div class="report-card bg-success text-white">
                                        <div class="report-card-icon">
                                            <i class="fas fa-receipt fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Transaction Journal</h6>
                                            <p class="report-card-description">Daily transaction report with selected vouchers</p>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Customer Aging -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/customer-aging" class="report-card-link">
                                    <div class="report-card bg-primary text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;">
                                        <div class="report-card-icon">
                                            <i class="fas fa-user-clock fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Customer Aging</h6>
                                            <p class="report-card-description">Analyze customer payment status and aging</p>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Supplier Aging -->
                            <div class="col-12 col-lg-4 col-md-6">
                                <a href="/reports/supplier-aging" class="report-card-link">
                                    <div class="report-card bg-info text-white" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%) !important;">
                                        <div class="report-card-icon">
                                            <i class="fas fa-truck fa-2x"></i>
                                        </div>
                                        <div class="report-card-content">
                                            <h6 class="report-card-title">Supplier Aging</h6>
                                            <p class="report-card-description">Track supplier payment obligations and aging</p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool connectionError = false;
    private ClientDashboardData dashboardData = new();
    private List<DashboardComparisonData> comparisonData = new();
    private List<ProductionDistributionData> productionData = new();
    private List<SalesDistributionData> salesData = new();
    private CEOReportResponse ceoReport = new();
    private string productionPeriod = "all";
    private string salesPeriod = "all";
    private bool isProductionLoading = false;
    private bool isSalesLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("chartHelper.initialize");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
        await LoadChartData();
    }

    private async Task LoadChartData()
    {
        try
        {
            // Load Comparison Chart (Sales, Recovery, Expenses) - All time
            comparisonData = await DataService.GetDashboardComparisonDataAsync();
            if (comparisonData != null && comparisonData.Any())
            {
                await Task.Delay(100);
                await JSRuntime.InvokeVoidAsync("chartHelper.renderDashboardChart", "comparisonChart", comparisonData);
            }
            StateHasChanged();

            // Load Distribution Charts
            await LoadProductionChart();
            await LoadSalesChart();

            // Load CEO Report Summary
            ceoReport = await DataService.GetCEOReportAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading chart data: {ex.Message}");
        }
    }

    private async Task LoadProductionChart()
    {
        isProductionLoading = true;
        StateHasChanged();
        
        try
        {
            DateTime? fromDate = null;
            DateTime toDate = DateTime.Now;

            if (productionPeriod == "all")
            {
                fromDate = null;
                toDate = DateTime.Now;
            }
            else if (productionPeriod == "today")
            {
                fromDate = DateTime.Today;
            }
            else if (productionPeriod == "week")
            {
                // Start of week (Sunday)
                fromDate = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek);
            }
            else if (productionPeriod == "month")
            {
                // Start of month
                fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
            }

            productionData = await DataService.GetProductionDistributionAsync(fromDate, toDate);
            
            if (productionData != null && productionData.Any())
            {
                // Give the UI time to render the canvas if it was hidden/loading
                await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("chartHelper.renderProductionChart", "productionChart", productionData);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading production chart: {ex.Message}");
        }
        finally
        {
            isProductionLoading = false;
            StateHasChanged();
        }
    }

    private async Task ChangeProductionPeriod(string period)
    {
        if (productionPeriod == period) return;
        
        productionPeriod = period;
        await LoadProductionChart();
    }

    private async Task LoadSalesChart()
    {
        isSalesLoading = true;
        StateHasChanged();
        
        try
        {
            DateTime? fromDate = null;
            DateTime toDate = DateTime.Now;

            if (salesPeriod == "all")
            {
                fromDate = null;
                toDate = DateTime.Now;
            }
            else if (salesPeriod == "today") fromDate = DateTime.Today;
            else if (salesPeriod == "week") fromDate = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek);
            else if (salesPeriod == "month") fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

            salesData = await DataService.GetSalesDistributionAsync(fromDate, toDate);
            
            if (salesData != null && salesData.Any())
            {
                await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("chartHelper.renderProductionChart", "salesChart", salesData);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sales chart: {ex.Message}");
        }
        finally
        {
            isSalesLoading = false;
            StateHasChanged();
        }
    }

    private async Task ChangeSalesPeriod(string period)
    {
        if (salesPeriod == period) return;
        salesPeriod = period;
        await LoadSalesChart();
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        connectionError = false;
        StateHasChanged();

        try
        {
            // Get dashboard data from the API
            var response = await DataService.GetDashboardDataAsync();
            if (response != null)
            {
                dashboardData = response;
            }
            
            // Check if we got empty data (likely connection issue)
            if (dashboardData.TotalSales == 0 && dashboardData.TotalPurchases == 0 && 
                dashboardData.TotalCustomers == 0 && dashboardData.TotalItems == 0)
            {
                connectionError = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
            connectionError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task TestConnection()
    {
        try
        {
            var isConnected = await DataService.TestClientConnectionAsync();
            if (isConnected)
            {
                connectionError = false;
                await LoadDashboardData();
            }
            else
            {
                connectionError = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error testing connection: {ex.Message}");
            connectionError = true;
        }
        StateHasChanged();
    }

}
